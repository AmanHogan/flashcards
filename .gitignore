# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
frontend/.next/**
frontend/out/
frontend/node_modules/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files — never commit these; copy the .example file and fill in your values
.env
.env.local
.env*.local
frontend/.env
frontend/.env.local
frontend/.env*.local

# local npm registry config — may contain auth tokens
.npmrc
frontend/.npmrc

# typescript
*.tsbuildinfo
next-env.d.ts

# Spring Boot — application.properties holds DB credentials, never commit
**/application.properties

# Maven build output
target/
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# IDEs
.idea
*.iws
*.iml
*.ipr
.vscode/
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
.apt_generated

# macOS
.DS_Store
